# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated list is fine; keep local dev + prod URL)
CORS_ORIGIN=http://localhost:5173

# Database
# Get this from MongoDB Atlas: Cluster > Connect > Drivers > Node.js
# Replace <user>, <password>, and <cluster> with your values.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chatapp?retryWrites=true&w=majority

# Optional: log level (error | warn | info | debug). Defaults to info.
# LOG_LEVEL=info
